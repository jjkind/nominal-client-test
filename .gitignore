# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/
ENV/

# Python build artifacts
build/
dist/
*.egg-info/
.eggs/

# Environment / secrets
.env
.env.*
!.env.example

# Docker / local runtime files
docker-compose.override.yml

# Local data folders
# Keep folder structure with .gitkeep files, but do not commit uploaded/generated data.
data/uploaded/*
data/processing/*
data/normalized/*
data/processed/*
data/failed/*
data/export_status/*

!data/uploaded/.gitkeep
!data/processing/.gitkeep
!data/normalized/.gitkeep
!data/processed/.gitkeep
!data/failed/.gitkeep
!data/export_status/.gitkeep

# Logs
*.log
logs/

# OS/editor files
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Jupyter / notebooks, if used during testing
.ipynb_checkpoints/

# Test/demo binary telemetry files
*.bin
*.dat
*.mf4
*.blf
*.pcap
*.pcapng

# Generated normalized telemetry files
*.jsonl
*.ndjson

# Local Elasticsearch data, if later mounted into the repo
elasticsearch-data/
kibana-data/